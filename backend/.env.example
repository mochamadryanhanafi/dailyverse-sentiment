DATABASE_URL=postgresql+asyncpg://dailyverse:dailyverse_secret@localhost:5432/dailyverse_db
APP_ENV=development
APP_TITLE=DailyVerse Sentiment API
APP_VERSION=1.0.0
SECRET_KEY=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id.apps.googleusercontent.com
ACCESS_TOKEN_EXPIRE_MINUTES=10080
DEFAULT_USER_ROLE=user
SCRAPER_PARALLELISM=2
SCRAPER_DELAY_SECONDS=2
SCRAPER_START_YEAR=2015
SCRAPER_END_YEAR=2024
SCRAPER_TOTAL_TARGET=600
